# Copy this file to .env for local development.
# The local runner uses the mock backend — no API keys needed.
#
# For production model backends, enterprise connectors, and deployment
# configuration, see the Niyam AIOL documentation.
# =============================================================================

# ---------------------------------------------------------------------------
# Local runner settings
# ---------------------------------------------------------------------------
NIYAM_LOG_LEVEL=INFO
NIYAM_OUTPUT_DIR=./outputs
